{
  "expo": {
    "name": "Palestra",
    "slug": "palestra-argentina",
    "version": "0.1.32",
    "orientation": "portrait",
    "icon": "./assets/logo-palestra.png",
    "scheme": "palestra",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-palestra.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F3F5"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2d8dc8",
      "androidMode": "default",
      "androidCollapsedTitle": "Palestra"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-palestra.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "org.palestra.argentina",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "palestra",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "bundleIdentifier": "org.palestra.argentina"
    },
    "extra": {
      "supabaseUrl": "https://lqnwdoehandtzxfzeghc.supabase.co",
      "supabaseAnonKey": "sb_publishable_VC-GuhM65eDiZxHSwmRF9w_tLK_xqdr",
      "eas": {
        "projectId": "ae3f9e9c-fa3d-4273-a840-e5796b9734d6"
      }
    },
    "plugins": [
      "expo-font",
      "expo-notifications"
    ]
  }
}
